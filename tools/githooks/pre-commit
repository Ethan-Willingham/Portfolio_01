#!/usr/bin/env bash
# Voice linter: blocks em dashes and the formulaic LLM tells from VOICE.md out of
# committed post content. Enabled per checkout with:
#   git config core.hooksPath tools/githooks
ROOT="$(git rev-parse --show-toplevel)"

# Engine-sync guard: the physics toy embeds verbatim copies of the game's
# smoke + jello engines (and shares liquid-wgpu.js). If a commit touches
# either side, refuse drift so every engine change ports both ways.
if git diff --cached --name-only | grep -qE '^(js/water-smoke-slime\.js|water-smoke-slime\.html|js/liquid-wgpu\.js|js/sluice/(190-smoke-webgl|340-jello|000-head)\.js)$'; then
  if ! node "$ROOT/tools/toy-engine-sync.mjs" --check; then
    echo "pre-commit: toy/game engine copies have drifted (see above)." >&2
    echo "  game changed -> node tools/toy-engine-sync.mjs --write" >&2
    echo "  toy block changed -> apply the diff to the game source, then --write" >&2
    exit 1
  fi
fi

exec bash "$ROOT/tools/voice-lint.sh"
